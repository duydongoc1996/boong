{
    "name": "@boong/api",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.13",
    "exports": {
        "./types": "./src/types.ts"
    },
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "start": "bun run dist/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "format": "biome check --write .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:seed": "ts-node -r tsconfig-paths/register drizzle/seeds/run-seed.ts",
        "db:studio": "drizzle-kit studio",
        "db:drop": "drizzle-kit drop",
        "envx:run": "dotenvx run --",
        "envx": "dotenvx",
        "exec": "ts-node -r tsconfig-paths/register ",
        "auth:info": "bunx auth@latest info --config ./lib/auth.ts",
        "auth:generate": "bunx auth@latest generate --config ./lib/auth.ts --output ./src/database/schemas/auth.ts"
    },
    "dependencies": {
        "@better-auth/i18n": "^1.6.10",
        "@elysia/cors": "^1.4.2",
        "@elysia/openapi": "^1.4.15",
        "@refinedev/simple-rest": "^6.0.1",
        "better-auth": "^1.6.9",
        "bun": "^1.3.13",
        "drizzle-orm": "^0.45.2",
        "elysia": "^1.4.28",
        "nanoid": "^5.1.11",
        "neverthrow": "^8.2.0",
        "openapi-types": "^12.1.3",
        "postgres": "^3.4.9",
        "uuid": "^14.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@boong/tsconfig": "workspace:*",
        "drizzle-kit": "^0.31.10",
        "typescript": "^6.0.3"
    }
}
