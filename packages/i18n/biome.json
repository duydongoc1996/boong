{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "root": false,
    "extends": "//",
    "files": {
        "includes": ["src/**/*", "!src/i18n/i18n-*.tsx", "!src/i18n/i18n-*.ts"]
    },
    "javascript": {
        "globals": ["Bun"]
    },
    "linter": {
        "rules": {
            "correctness": {
                "useExhaustiveDependencies": "off",
                "useHookAtTopLevel": "off"
            }
        }
    }
}
