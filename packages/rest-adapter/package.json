{
    "name": "@bunti/rest-adapter",
    "version": "0.0.1",
    "private": true,
    "description": "REST Adapter for Bunti, enabling seamless REST API interactions.",
    "license": "MIT",
    "author": "Bunti",
    "type": "module",
    "packageManager": "bun@1.3.13",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "files": ["dist"],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch",
        "prepare": "bun run build",
        "typecheck": "tsc -p tsconfig.json",
        "lint": "biome check .",
        "format": "biome check --write ."
    },
    "dependencies": {
        "axios": "^1.11.0",
        "qs": "^6.15.1"
    },
    "devDependencies": {
        "@types/qs": "^6.15.1",
        "@esbuild-plugins/node-resolve": "^0.1.4",
        "@refinedev/cli": "^2.16.50",
        "@refinedev/core": "^5.0.5",
        "@biomejs/biome": "2.4.14",
        "@bunti/tsconfig": "workspace:*",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@refinedev/core": "^5.0.12"
    },
    "engines": {
        "node": ">=22"
    },
    "publishConfig": {
        "access": "public"
    }
}
